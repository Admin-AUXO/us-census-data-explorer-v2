# Dependencies
node_modules/
yarn.lock
pnpm-lock.yaml

# Build outputs
dist/
dist-ssr/
*.local

# Data files (generated, too large for git)
data/*.csv
data/manifest.json

# Logs
logs/*
!logs/.gitkeep
*.log
*.err
*.err.log
*.tmp
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.playwright-cli/
.playwright-mcp/
test-results/
output/
playwright-report.json
nul

# Editor directories
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Environment
.env
.env.local
.env.*.local

# Cache
.cache/
.vite/
*.tsbuildinfo

# Documentation (keep only README.md and DEPLOY.md)
*.md
!README.md
!DEPLOY.md

# OS files
Thumbs.db
desktop.ini
