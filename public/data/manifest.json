{
  "metadata": {
    "description": "US Census ACS 5-Year Estimates for executive business intelligence",
    "source": "U.S. Census Bureau American Community Survey (ACS) 5-Year Estimates",
    "version": "2018-2024",
    "generated_at": "2026-05-03"
  },
  "derived_metrics": {
    "homeownership_rate": {
      "formula": "owner_occupied / total_housing_units",
      "description": "Percentage of housing units that are owner-occupied",
      "format": "percent"
    },
    "renter_rate": {
      "formula": "renter_occupied / total_housing_units",
      "description": "Percentage of housing units that are renter-occupied",
      "format": "percent"
    },
    "housing_vacancy_rate": {
      "formula": "vacant_units / total_housing_units",
      "description": "Percentage of housing units that are vacant",
      "format": "percent"
    },
    "price_to_income_ratio": {
      "formula": "median_home_value / median_household_income",
      "description": "Home price to income ratio (5+ indicates expensive market)",
      "format": "ratio"
    },
    "rent_burden": {
      "formula": "median_gross_rent / median_household_income",
      "description": "Income spent on rent (30%+ is cost-burdened)",
      "format": "percent"
    },
    "gross_rental_yield": {
      "formula": "(median_gross_rent * 12) / median_home_value * 100",
      "description": "Annual gross rental yield as percentage of property value",
      "format": "percent"
    },
    "unemployment_rate": {
      "formula": "unemployed / in_labor_force",
      "description": "Percentage of labor force unemployed",
      "format": "percent"
    },
    "employment_rate": {
      "formula": "employed / in_labor_force",
      "description": "Percentage of labor force employed",
      "format": "percent"
    },
    "labor_force_participation": {
      "formula": "in_labor_force / population",
      "description": "Working-age population in labor force",
      "format": "percent"
    },
    "poverty_rate": {
      "formula": "below_poverty_line / population",
      "description": "Population below poverty line",
      "format": "percent"
    },
    "bachelors_degree_rate": {
      "formula": "bachelors_degree / total_pop_25plus",
      "description": "Adults 25+ with bachelor's degree",
      "format": "percent"
    },
    "college_educated_rate": {
      "formula": "(bachelors + masters + doctorate) / total_pop_25plus",
      "description": "Adults 25+ with college degree or higher",
      "format": "percent"
    },
    "digital_access_score": {
      "formula": "(computer_access_rate * 0.4 + broadband_access_rate * 0.6) * 100",
      "description": "Composite digital access indicator (0-100)",
      "format": "score"
    },
    "insured_rate": {
      "formula": "insured / population",
      "description": "Percentage with health insurance",
      "format": "percent"
    },
    "market_opportunity_score": {
      "formula": "0.30*income_score + 0.25*digital_score + 0.25*education_score + 0.20*employment_score",
      "description": "Composite market opportunity score (0-100)",
      "format": "score"
    },
    "economic_resilience_score": {
      "formula": "weighted employment + labor + poverty + inequality",
      "description": "Economic stability and resilience indicator (0-100)",
      "format": "score"
    },
    "housing_affordability_index": {
      "formula": "100 - (price_to_income_ratio/10*50 + rent_burden/0.5*50)",
      "description": "Composite housing affordability (0-100, higher = more affordable)",
      "format": "score"
    },
    "gini_index": {
      "formula": "income inequality coefficient",
      "description": "Income inequality (0=perfect equality, 1=perfect inequality)",
      "format": "index"
    },
    "consumer_spending_power": {
      "formula": "median_household_income * (1 - rent_burden)",
      "description": "Income adjusted for housing costs",
      "format": "currency"
    },
    "population_density": {
      "formula": "total_population / land_area_sq_km",
      "description": "Residents per square kilometer",
      "format": "number",
      "label": "Population Density",
      "category": "market_size"
    },
    "housing_density": {
      "formula": "total_housing_units / land_area_sq_km",
      "description": "Housing units per square kilometer",
      "format": "number",
      "label": "Housing Density",
      "category": "housing_market"
    },
    "prosperity_index": {
      "formula": "weighted income + employment + inverse poverty",
      "description": "Composite affluence and labor health score",
      "format": "score",
      "label": "Prosperity Index",
      "category": "executive_signal"
    },
    "affluence_index": {
      "formula": "weighted household income + per-capita income + affluent households",
      "description": "Household wealth concentration score",
      "format": "score",
      "label": "Affluence Index",
      "category": "purchasing_power"
    },
    "market_momentum_index": {
      "formula": "average of market opportunity, resilience, and digital access",
      "description": "Forward-looking market quality score",
      "format": "score",
      "label": "Market Momentum",
      "category": "composite_scores"
    },
    "cost_pressure_index": {
      "formula": "weighted price-to-income + rent burden + inverse affordability",
      "description": "Operating and affordability pressure score",
      "format": "score",
      "label": "Cost Pressure",
      "category": "risk"
    },
    "talent_depth_index": {
      "formula": "weighted college attainment + labor force + employment",
      "description": "Workforce strength score",
      "format": "score",
      "label": "Talent Depth",
      "category": "workforce"
    },
    "executive_growth_score": {
      "formula": "average of prosperity, market momentum, talent depth, and inverse cost pressure",
      "description": "Executive summary score for scalable growth",
      "format": "score",
      "label": "Executive Growth Score",
      "category": "composite_scores"
    },
    "consumer_demand_index": {
      "formula": "weighted income, spending power, digital access, and population scale",
      "description": "Composite local demand score",
      "format": "score",
      "label": "Consumer Demand",
      "category": "purchasing_power"
    },
    "senior_services_index": {
      "formula": "weighted elderly population, public coverage, and resilience",
      "description": "Potential demand for senior-focused services",
      "format": "score",
      "label": "Senior Services Index",
      "category": "healthcare"
    },
    "logistics_access_index": {
      "formula": "weighted vehicle access, broadband, work-from-home, and digital access",
      "description": "Operational access and last-mile readiness score",
      "format": "score",
      "label": "Logistics Access",
      "category": "operational_readiness"
    }
  },
